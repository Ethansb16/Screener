# SEC EDGAR User-Agent — required by SEC policy
# Format: AppName contact@email.com
SEC_USER_AGENT=SpinoffScreener your@email.com

# Anthropic API key — needed for Phase 4
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Server port
PORT=3000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Cron schedule (default: 7 AM daily)
CRON_SCHEDULE=0 7 * * *
